@page "/lucide-demo"
@using Soenneker.Quark.Gen.Lucide.Abstractions
@inject ILucideIconSvgProvider SvgProvider

<PageTitle>Lucide Gen Demo</PageTitle>

<h1>Lucide Gen Demo</h1>

<p>Generated <code>ILucideIconSvgProvider</code> and <code>LucideIconSvgProvider</code> — no Quark Suite dependency.</p>

<div class="space-y-6 mt-6">
    <section>
        <h2 class="text-lg font-semibold mb-3">Icons via generated provider</h2>
        <div class="flex flex-wrap gap-4 items-center">
            @foreach (var name in new[] { "AArrowDown", "Check", "Activity", "Heart" })
            {
                var svg = SvgProvider?.GetSvg(name);
                if (!string.IsNullOrEmpty(svg))
                {
                    <span class="inline-block size-6" style="vertical-align: middle">@((MarkupString)svg)</span>
                }
            }
        </div>
    </section>
</div>
